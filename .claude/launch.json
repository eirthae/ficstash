{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "ficstash-app",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "app",
      "port": 5173
    },
    {
      "name": "ficstash-intake",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "5176"],
      "cwd": "intake",
      "port": 5176
    },
    {
      "name": "bookstash",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--port", "5189", "--strictPort"],
      "cwd": "../bookstash",
      "port": 5189
    }
  ]
}
